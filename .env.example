# =============================================================================
# WaldosLair — Environment varijable
# =============================================================================
#
# UPUTE:
#   1. Kopiraj ovu datoteku u .env:  cp .env.example .env
#   2. Postavi svoju lozinku umjesto placeholder vrijednosti
#   3. NIKAD ne commitas .env na GitHub!
#      .env je već u .gitignore — provjeri prije pusha.
#
# Na produkcijskom serveru (ThinkCentre / waldoslair):
#   Postavi varijable direktno u systemd service file:
#   Environment="ACCESS_CODE=tvoja_lozinka"
#   ili koristi: sudo systemctl edit waldoslair.service
#
# =============================================================================

# Lozinka za pristup aplikaciji
# Preporučena duljina: minimalno 16 znakova
# Preporučeni format: kombinacija velikih/malih slova, brojeva i simbola
# Primjer generiranja: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
ACCESS_CODE=PROMIJENI_OVO_U_SVOJU_JAKU_LOZINKU

# (Opcionalno) Debug mode — postavi na False u produkciji
# DEBUG=False

# (Opcionalno) Putanja do baze podataka (default: ./finance.db)
# DB_PATH=/custom/path/to/finance.db
